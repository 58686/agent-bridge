{
  "name": "agent-bridge",
  "version": "1.0.0",
  "description": "Safe runtime for connecting AI agents to company tools, workflows, and APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent": "dist/main.js",
    "agent-server": "dist/server-main.js",
    "agent-bridge": "dist/server-main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "dev:server": "tsx watch src/server-main.ts",
    "start": "node dist/main.js",
    "start:server": "node dist/server-main.js",
    "demo": "node dist/main.js demo",
    "cli": "node dist/main.js run",
    "serve": "node dist/server-main.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "automation",
    "framework"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.55.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
