# OpenAI model
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use a custom OpenAI-compatible base URL
# OPENAI_BASE_URL=https://your-openai-gateway.example.com/v1

# HTTP API auth
# Set to true to require Bearer token authentication for all endpoints except /health
API_AUTH_ENABLED=false

# Format: token:actorId:role,token:actorId:role
# Roles: viewer | operator | approver | admin
# Example:
# API_AUTH_TOKENS=viewer-token:viewer-1:viewer,operator-token:operator-1:operator,approver-token:approver-1:approver
API_AUTH_TOKENS=

# Example connector secrets
TICKET_API_TOKEN=example-ticket-token
WORKFLOW_API_TOKEN=example-workflow-token
